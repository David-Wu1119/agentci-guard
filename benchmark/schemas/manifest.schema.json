{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/David-Wu1119/agentci-guard/benchmark/schemas/manifest.schema.json",
  "title": "AgentCI Guard frozen benchmark manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "benchmark_id",
    "status",
    "frozen_at",
    "collection_seed",
    "sampling_frame",
    "split_method",
    "workflow_count",
    "repository_count",
    "annotation_schema_version",
    "annotation_schema",
    "annotation_unit",
    "agent_detection_task",
    "independent_review_plan",
    "minimum_positive_support_for_percentage_claims",
    "minimum_independent_review_coverage",
    "qualification_targets",
    "task_granularity",
    "rules",
    "cases",
    "supersedes",
    "heldout_diversity_collection_seed",
    "heldout_diversity_target_per_configuration",
    "development_reclassified_case_ids",
    "heldout_case_ids"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "benchmark_id": {
      "const": "agentci-real-workflows-v3"
    },
    "status": {
      "enum": ["unlabeled", "labeling", "adjudicated", "evaluated"]
    },
    "frozen_at": {
      "type": "string",
      "format": "date-time"
    },
    "collection_seed": {
      "type": "string",
      "minLength": 1
    },
    "sampling_frame": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "query", "requested_results"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "requested_results": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "split_method": {
      "type": "string",
      "minLength": 1
    },
    "workflow_count": {
      "type": "integer",
      "minimum": 100
    },
    "repository_count": {
      "type": "integer",
      "minimum": 50
    },
    "annotation_schema_version": {
      "const": 2
    },
    "annotation_schema": {
      "const": "benchmark/schemas/annotation-record.schema.json"
    },
    "annotation_unit": {
      "const": "(workflow, job, step-or-job scope, task, reachable state)"
    },
    "agent_detection_task": {
      "const": "agentci/agent-usage"
    },
    "independent_review_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed", "remaining_unit_sample_rate", "always_review_tasks"],
      "properties": {
        "seed": {
          "type": "string",
          "minLength": 1
        },
        "remaining_unit_sample_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "always_review_tasks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^agentci/"
          }
        }
      }
    },
    "minimum_positive_support_for_percentage_claims": {
      "type": "integer",
      "minimum": 1
    },
    "minimum_independent_review_coverage": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "qualification_targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_detection_precision",
        "agent_detection_recall",
        "security_micro_precision",
        "security_supported_recall",
        "decision_coverage",
        "high_critical_rule_precision"
      ],
      "properties": {
        "agent_detection_precision": {
          "$ref": "#/$defs/rate"
        },
        "agent_detection_recall": {
          "$ref": "#/$defs/rate"
        },
        "security_micro_precision": {
          "$ref": "#/$defs/rate"
        },
        "security_supported_recall": {
          "$ref": "#/$defs/rate"
        },
        "decision_coverage": {
          "$ref": "#/$defs/rate"
        },
        "high_critical_rule_precision": {
          "$ref": "#/$defs/rate"
        }
      }
    },
    "task_granularity": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "enum": ["job", "step"]
      },
      "propertyNames": {
        "pattern": "^agentci/"
      }
    },
    "supersedes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["benchmark_id", "manifest", "reason"],
      "properties": {
        "benchmark_id": {
          "const": "agentci-real-workflows-v2"
        },
        "manifest": {
          "const": "benchmark/archive/agentci-real-workflows-v2/manifest.json"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "heldout_diversity_collection_seed": {
      "type": "string",
      "minLength": 1
    },
    "heldout_diversity_target_per_configuration": {
      "const": 4
    },
    "development_reclassified_case_ids": {
      "$ref": "#/$defs/caseIdSet"
    },
    "heldout_case_ids": {
      "$ref": "#/$defs/caseIdSet"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^agentci/"
      }
    },
    "cases": {
      "type": "array",
      "minItems": 100,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "caseIdSet": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "split",
        "stratum",
        "repository",
        "repository_url",
        "source_path",
        "source_url",
        "source_commit",
        "blob_sha",
        "sha256",
        "bytes",
        "license",
        "snapshot_path"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "split": {
          "enum": ["dev", "eval"]
        },
        "stratum": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "repository_url": {
          "type": "string",
          "format": "uri"
        },
        "source_path": {
          "type": "string",
          "pattern": "^\\.github/workflows/[^/]+\\.ya?ml$"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "blob_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_path": {
          "type": "string",
          "pattern": "^benchmark/snapshots/"
        },
        "configuration_family": {
          "type": "string",
          "minLength": 1
        },
        "selection_key": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "selection_round": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
