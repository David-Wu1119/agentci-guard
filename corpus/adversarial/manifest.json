{
  "schema_version": 2,
  "purpose": "Synthetic adversarial regression corpus; not an accuracy benchmark.",
  "labeling_policy": "Expected outputs are manually authored from the documented rule contract, not copied from scanner output.",
  "security_assumptions": {
    "environment-precedence": {
      "type": "primary",
      "title": "GitHub Actions workflow syntax: env",
      "url": "https://docs.github.com/en/actions/reference/workflows-and-actions/workflow-syntax#env",
      "claim": "Step env overrides job env, and job env overrides workflow env."
    },
    "event-expressions": {
      "type": "primary",
      "title": "GitHub Actions expressions",
      "url": "https://docs.github.com/en/actions/reference/evaluate-expressions-in-workflows-and-actions",
      "claim": "Job and step conditions use boolean expressions and GitHub contexts."
    },
    "event-security": {
      "type": "primary",
      "title": "Events that trigger workflows",
      "url": "https://docs.github.com/en/actions/reference/events-that-trigger-workflows",
      "claim": "Event payloads and pull_request_target execution context determine attacker influence and privilege."
    },
    "checkout-protection": {
      "type": "primary",
      "title": "Safer pull_request_target defaults for GitHub Actions checkout",
      "url": "https://github.blog/changelog/2026-06-18-safer-pull_request_target-defaults-for-github-actions-checkout/",
      "claim": "Current floating supported checkout majors refuse common fork-PR head and merge checkouts unless allow-unsafe-pr-checkout explicitly opts out; immutable and older refs require version-aware treatment."
    },
    "permissions": {
      "type": "primary",
      "title": "GitHub Actions workflow syntax: permissions",
      "url": "https://docs.github.com/en/actions/reference/workflows-and-actions/workflow-syntax#permissions",
      "claim": "Workflow and job permissions determine the effective GITHUB_TOKEN capability."
    },
    "reusable-workflows": {
      "type": "primary",
      "title": "Reuse workflows",
      "url": "https://docs.github.com/en/actions/how-tos/sharing-automations/reusing-workflows",
      "claim": "Local reusable workflows inherit caller context subject to explicit inputs, secrets, and permissions."
    },
    "project-analysis-contract": {
      "type": "project",
      "title": "AgentCI Guard analysis contract",
      "url": "../../docs/analysis-model.md",
      "claim": "Unknown permissions, unsupported event conditions, parse failures, and unresolved reusable workflows must be explicit diagnostics."
    },
    "project-rule-contract": {
      "type": "project",
      "title": "AgentCI Guard rule contract",
      "url": "../../RULES.md",
      "claim": "Agent identification, source, sink, capability, permission, pinning, and checkout behavior determine rule outcomes."
    }
  },
